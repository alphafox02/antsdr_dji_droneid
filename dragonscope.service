[Unit]
Description=DragonScope
After=network-online.target
Wants=network-online.target

[Service]
User=root
WorkingDirectory=/home/dragon/WarDragon/antsdr_dji_droneid
ExecStart=/usr/bin/python3 /home/dragon/WarDragon/antsdr_dji_droneid/dragonscope.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
